{
  "name": "@sisal/example-mysql-family-feed",
  "version": "0.9.0",
  "exports": "./mod.ts",
  "publish": false,
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "migrate": "deno run --env-file=.env --allow-env --allow-net --allow-read src/migrate.ts",
    "reset": "deno run --env-file=.env --allow-env --allow-net --allow-read src/migrate.ts --reset",
    "seed": "deno run --env-file=.env --allow-env --allow-net --allow-read src/seed.ts",
    "demo": "deno run --env-file=.env --allow-env --allow-net --allow-read src/main.ts",
    "recompute": "deno run --env-file=.env --allow-env --allow-net --allow-read src/recompute.ts",
    "recompute:ctes": "deno run --env-file=.env --allow-env --allow-net --allow-read src/recompute_ctes.ts",
    "test": "deno test --allow-read"
  }
}
