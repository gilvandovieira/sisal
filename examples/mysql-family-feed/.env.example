# Runtime connection. MYSQL_URL wins, then MARIADB_URL, then DATABASE_URL.
MYSQL_URL=mysql://root:root@localhost:33084/sisal
# MARIADB_URL=mysql://root:root@localhost:33110/sisal

# Driver: mysql2 (default) or mariadb.
SISAL_ADAPTER=mysql2

# Gated live tests:
# SISAL_MYSQL_RISING_FEED_IT=1
# SISAL_MARIADB_RISING_FEED_IT=1
