# Copy this file to .env and run the bundled tasks (they pass --env-file=.env):
#
#   docker compose up -d    # start PostgreSQL 18 locally
#   deno task migrate       # apply migrations
#   deno task seed          # insert deterministic posts + activity
#   deno task demo          # run the full demo (/new, /rising, reorder)
#   deno task recompute     # recalculate stored rising scores
#   deno task reset         # drop everything, then re-migrate
#
# This is the NORMAL PostgreSQL 18 example: a regular TCP/session connection,
# no serverless/single-statement constraint. The docker-compose.yml in this
# folder brings up postgres:18 matching these defaults.

# App / runtime queries.
DATABASE_URL=postgres://sisal:sisal@localhost:5432/sisal_rising_feed

# Migrations / admin work. For normal Postgres this is the same as DATABASE_URL;
# kept as a separate name so the example mirrors the Neon one structurally.
# Falls back to DATABASE_URL if unset.
DATABASE_DIRECT_URL=postgres://sisal:sisal@localhost:5432/sisal_rising_feed
