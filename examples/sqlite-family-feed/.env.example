# Copy this file to .env to point the example at a Turso database. If you leave
# these unset, the example runs against a local SQLite file
# (file:./sisal-rising-feed.db) — no .env needed to try it out:
#
#   deno task migrate      # apply the single schema migration
#   deno task seed         # insert deterministic posts + activity
#   deno task demo         # run the full demo (/new, /rising, reorder)
#   deno task recompute    # recalculate stored rising scores
#   deno task reset        # drop everything, then re-migrate

# Turso / remote libSQL. Leave unset to use the local file default.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Local file override (optional). Defaults to file:./sisal-rising-feed.db.
# SISAL_LIBSQL_URL=file:./sisal-rising-feed.db
