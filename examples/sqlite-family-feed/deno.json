{
  "name": "@sisal/example-sqlite-family-feed",
  "version": "0.10.0",
  "exports": "./mod.ts",
  "publish": false,
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "migrate": "deno run --env-file=.env --allow-env --allow-net --allow-read --allow-write --allow-ffi --allow-sys src/migrate.ts",
    "reset": "deno run --env-file=.env --allow-env --allow-net --allow-read --allow-write --allow-ffi --allow-sys src/migrate.ts --reset",
    "seed": "deno run --env-file=.env --allow-env --allow-net --allow-read --allow-write --allow-ffi --allow-sys src/seed.ts",
    "demo": "deno run --env-file=.env --allow-env --allow-net --allow-read --allow-write --allow-ffi --allow-sys src/main.ts",
    "recompute": "deno run --env-file=.env --allow-env --allow-net --allow-read --allow-write --allow-ffi --allow-sys src/recompute.ts",
    "test": "deno test --allow-read"
  }
}
