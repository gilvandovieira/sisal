# Copy this file to .env and fill in your Neon connection strings, then run the
# bundled tasks (they pass --env-file=.env for you):
#
#   deno task migrate      # apply migrations (uses DATABASE_DIRECT_URL)
#   deno task seed         # insert deterministic demo posts + activity
#   deno task generate     # build + store feature vectors for all posts
#   deno task demo         # run the full demo (seed + generate + similarity)
#   deno task reset        # drop everything, then re-migrate

# App / runtime queries. For Neon, the POOLED url is usually preferred here
# (host contains "-pooler"). Every runtime query in this example is a single
# statement, which suits Neon serverless / Deno Deploy.
DATABASE_URL=postgres://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Migrations / admin work. The DIRECT (non-pooled) url is commonly preferred for
# migrations (host has no "-pooler"). Falls back to DATABASE_URL if unset.
DATABASE_DIRECT_URL=postgres://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
