# Sisal integration-test environment — copy to `.env` and adjust.
#
#   cp .env.example .env
#
# `.env` is gitignored; this template is committed. IMPORTANT: Deno does NOT
# auto-load .env — pass it explicitly to the gated suites:
#
#   deno test --env-file=.env -A integration/libsql_features_test.ts
#   deno test --env-file=.env -A integration/sqlite_features_test.ts
#   deno test --env-file=.env -A integration/pg_features_test.ts
#   deno test --env-file=.env -A integration/neon_features_test.ts
#
# The network/FFI-free unit run (`deno task test`) does not read this file, so it
# stays clean regardless of what is set here.
#
# Gotcha: in a .env an empty value (FOO=) is NOT the same as "unset" — the suites
# read some vars with `?? undefined`, so an empty string can break the default
# path. For optional vars, leave the line COMMENTED OUT rather than blank.

# ── PostgreSQL (@sisal/pg) ──────────────────────────────────────────────────
# docker compose -f docker/compose.yaml up -d pg16 pg17 pg18
# Host ports: pg16=55416, pg17=55417, pg18=55418.
DATABASE_URL=postgres://postgres:postgres@localhost:55418/sisal

# ── Neon (@sisal/neon) ──────────────────────────────────────────────────────
# Local path (recommended, offline): docker compose -f docker/compose.yaml up -d
# neon-proxy  — Neon's wsproxy image bridging to postgres:17. Keep NEON_WS_PROXY
# set for this path.
NEON_DATABASE_URL=postgres://postgres:postgres@localhost/sisal
NEON_WS_PROXY=localhost:5499
# Real Neon instead: set NEON_DATABASE_URL to your endpoint
# (postgres://…@ep-xxx.neon.tech/db?sslmode=require) and COMMENT OUT
# NEON_WS_PROXY — the driver speaks secure WebSocket directly, and an empty
# NEON_WS_PROXY value breaks it.

# ── SQLite (@sisal/sqlite) — embedded, no server ────────────────────────────
SISAL_SQLITE_IT=1

# ── libSQL / Turso (@sisal/libsql) ──────────────────────────────────────────
SISAL_LIBSQL_IT=1
# Remote Turso (optional). Omit BOTH lines to use a local temp file; an empty
# TURSO_DATABASE_URL breaks the local-file fallback, so keep them commented.
# TURSO_DATABASE_URL=libsql://<db>.turso.io
# TURSO_AUTH_TOKEN=<token>

# ── Example gated suites (optional; set to 1 to enable) ─────────────────────
# SISAL_NEON_HOT_FEED_IT=1
# SISAL_NEON_RISING_FEED_IT=1
# SISAL_NEON_RISING_CTE_FEED_IT=1
# SISAL_LIBSQL_RISING_FEED_IT=1
# SISAL_POSTGRES_RISING_FEED_IT=1
