{
  "name": "@sisal/neon",
  "version": "0.11.0",
  "exports": {
    ".": "./mod.ts",
    "./orm": "./src/orm/mod.ts",
    "./migrate": "./src/migrate/mod.ts",
    "./ddl": "./src/ddl.ts"
  },
  "imports": {
    "@neon/serverless": "jsr:@neon/serverless@^1.0.0"
  },
  "license": "MIT",
  "description": "Neon serverless PostgreSQL adapter boundaries for Sisal ORM and migrations.",
  "keywords": [
    "deno",
    "jsr",
    "sisal",
    "neon",
    "serverless",
    "postgres",
    "orm",
    "migrations"
  ],
  "publish": {
    "include": [
      "README.md",
      "mod.ts",
      "src/**/*.ts",
      "deno.json"
    ],
    "exclude": [
      "**/*_test.ts"
    ]
  }
}
