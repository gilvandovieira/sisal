    "./migrate": "./src/migrate/mod.ts",
    "./ddl": "./src/migrate/ddl.ts"
  },
  "license": "MIT",
  "description": "libSQL and Turso adapter boundaries for Sisal ORM and migrations.",
  "keywords": [
    "deno",
