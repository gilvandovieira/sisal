{
  "name": "@sisal/migrate",
  "version": "0.6.0",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts",
    "./core": "./core/mod.ts",
    "./workflow": "./core/workflow.ts"
  },
  "license": "MIT",
  "description": "Migration planning, diffing, and running primitives for Sisal.",
  "keywords": [
    "deno",
    "jsr",
    "sisal",
    "migrations",
    "database",
    "schema"
  ],
  "publish": {
