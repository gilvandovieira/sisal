{
  "name": "@sisal/sqlite",
  "version": "0.12.0",
  "exports": {
    ".": "./mod.ts",
    "./orm": "./src/orm/mod.ts",
    "./migrate": "./src/migrate/mod.ts",
    "./ddl": "./src/migrate/ddl.ts"
  },
  "license": "MIT",
  "description": "SQLite adapter for Sisal: embedded, typed ORM execution with dialect-aware SQL rendering and migrations.",
  "keywords": [
    "deno",
    "jsr",
    "sisal",
    "sqlite",
    "orm",
    "migrations"
  ],
  "publish": {
    "include": [
      "README.md",
      "mod.ts",
      "src/**/*.ts",
      "deno.json"
    ],
    "exclude": [
      "**/*_test.ts"
    ]
  }
}
